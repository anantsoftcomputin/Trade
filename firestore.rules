rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function ownsExisting() { return signedIn() && resource.data.ownerId == request.auth.uid; }

    match /users/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }
    match /trainingJobs/{jobId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /models/{modelId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /signals/{signalId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /paperTrades/{tradeId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /conversations/{conversationId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /auditEvents/{eventId} {
      allow read: if ownsExisting();
      allow write: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
